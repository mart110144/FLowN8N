    {
      "parameters": {
        "jsCode": "// วนลูปข้อมูลทุก item ที่เข้ามาจาก node ก่อนหน้า\nfor (const item of $input.all()) {\n\n  // คำนวณราคา Bitcoin เป็นเงินบาท\n  // โดยเอาราคา BTC (USD) คูณกับอัตราแลกเปลี่ยน USD → THB\n  item.json.btc_thb_price = item.json.btc_usd_price * item.json.usd_to_thb;\n\n  // คำนวณราคาทองคำเป็นเงินบาท\n  // โดยเอาราคาทอง (USD) คูณกับอัตราแลกเปลี่ยน USD → THB\n  item.json.gold_thb_price = item.json.gold_usd_price * item.json.usd_to_thb;\n}\n\n// ส่งข้อมูลทั้งหมด (ที่ถูกเพิ่ม field ใหม่แล้ว) ออกไปยัง node ถัดไป\nreturn $input.all();"
      },
